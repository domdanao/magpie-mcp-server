# Magpie API Configuration
MAGPIE_PUBLIC_KEY=your_public_key_here
MAGPIE_SECRET_KEY=your_secret_key_here
MAGPIE_TEST_MODE=false

# Optional: Custom API base URLs (for testing or custom deployments)
# MAGPIE_PAYMENTS_BASE_URL=https://api.magpie.im
# MAGPIE_CHECKOUT_BASE_URL=https://api.pay.magpie.im
# MAGPIE_REQUESTS_BASE_URL=https://request.magpie.im/api
# MAGPIE_LINKS_BASE_URL=https://buy.magpie.im/api

# HTTP Server Configuration (for remote/HTTP mode only — used by npm run start:http)
# PORT=3000
# MCP_AUTH_ISSUER_URL=http://localhost:3000
# MCP_AUTH_TOKEN_EXPIRY=3600